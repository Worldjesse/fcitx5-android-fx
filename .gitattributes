plugin/rime/src/main/cpp/wanxiang/*.yaml text eol=lf
plugin/rime/src/main/cpp/wanxiang/*.dict.yaml text eol=lf
plugin/rime/src/main/cpp/wanxiang/*.txt text eol=lf
plugin/rime/src/main/cpp/wanxiang/lua/wanxiang/*.lua text eol=lf
