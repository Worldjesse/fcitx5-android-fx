<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:minHeight="?attr/actionBarSize" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/update_mirror_name_label"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/mirrorNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/update_mirror_name_hint"
            android:maxLines="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/update_mirror_pattern_label"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/mirrorPatternInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/update_mirror_pattern_hint"
            android:inputType="text"
            android:maxLines="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/update_mirror_replace_label"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/mirrorReplacementInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/update_mirror_replace_hint"
            android:inputType="text"
            android:maxLines="1" />
    </LinearLayout>
</LinearLayout>
